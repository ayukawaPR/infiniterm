{
  "name": "infiniterm",
  "version": "0.1.0",
  "description": "Electron-based terminal client with Japanese support and tmux compatibility",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "patch-pty": "node scripts/patch-node-pty.js",
    "rebuild-pty": "node scripts/rebuild-pty.js",
    "setup": "npm install --ignore-scripts && npm run patch-pty && npm run rebuild-pty",
    "package": "npm run build && electron-builder --config",
    "package:win": "npm run build && electron-builder --win --config",
    "package:mac": "npm run build && electron-builder --mac --config"
  },
  "build": {
    "appId": "com.infiniterm.app",
    "productName": "infiniterm",
    "copyright": "MIT",
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "infiniterm",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "infiniterm-portable.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.11.14",
    "qrcode": "^1.5.4",
    "ssh2": "^1.17.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "css-loader": "^6.10.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
